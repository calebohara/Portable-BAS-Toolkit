{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BAU Suite",
  "version": "4.8.2",
  "identifier": "com.bau-suite.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:static"
  },
  "app": {
    "windows": [
      {
        "title": "BAU Suite — Portable Project Toolkit",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: asset: https://asset.localhost https://*.supabase.co; font-src 'self'; connect-src 'self' ws: wss: http: https:; frame-src blob: http: https:; object-src 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/calebohara/Portable-BAS-Toolkit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDMzEyMkQ5NjBFMzdDMjYKUldRbWZPTmcyU0l4ekRxUUZIa1NKZm5lemZyVDNGRktlbkwrZDBrZmRZU0dBbG5NL2ZIRll4Rk8K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": "-",
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
